# Plantilla de variables de entorno para Docker Compose y pruebas locales.
# Copie a ".env" en la raíz:  cp .env.example .env
#
# En Azure App Service, estos valores suelen venir de Key Vault / configuración
# (la app solo ve el resultado, igual que con un .env en local).

MSSQL_SA_PASSWORD=RickMorty_Dev_2024!

ASPNETCORE_ENVIRONMENT=Development
DATABASE__PROVIDER=SqlServer

CONNECTIONSTRINGS__DEFAULTCONNECTION=Server=sql,1433;Database=RickAndMortyDb;User Id=sa;Password=RickMorty_Dev_2024!;TrustServerCertificate=True;Encrypt=False

RICKANDMORTYAPI__BASEURL=https://rickandmortyapi.com/api/

KEYVAULT_VAULTURI=

# Key Vault (referencia de nombres de secretos, opcional):
#   ConnectionStrings--DefaultConnection  ->  ConnectionStrings:DefaultConnection
